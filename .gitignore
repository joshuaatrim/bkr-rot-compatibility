# ------------------------------------------------------------
# Bannerlord module build output
# ------------------------------------------------------------
# Keep the module folder structure, but do not commit compiled files.

module/**/bin/Win64_Shipping_Client/*.dll
module/**/bin/Win64_Shipping_Client/*.pdb
module/**/bin/Win64_Shipping_Client/*.xml
module/**/bin/Win64_Shipping_Client/*.mdb

module/**/bin/Gaming.Desktop.x64_Shipping_Client/*.dll
module/**/bin/Gaming.Desktop.x64_Shipping_Client/*.pdb
module/**/bin/Gaming.Desktop.x64_Shipping_Client/*.xml
module/**/bin/Gaming.Desktop.x64_Shipping_Client/*.mdb

# Temporary copied module folders or deployment output
deploy/
dist/
release/
releases/
package/
packages-output/
*.zip
*.7z
*.rar

# ------------------------------------------------------------
# Local game/mod dependency references
# ------------------------------------------------------------
# Do not commit TaleWorlds, Banner Kings Redux, Realm of Thrones,
# BLSE, Harmony, ButterLib, MCM, UIExtenderEx, or other external binaries.

external/*
!external/README.md
!external/.gitkeep

lib/*
!lib/README.md
!lib/.gitkeep

references/*
!references/README.md
!references/.gitkeep

